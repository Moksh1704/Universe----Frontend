{
  "expo": {
    "name": "UniVerse",
    "slug": "universe-au",
    "owner": "karthik2569",
    "scheme": "universe",
    "version": "1.0.0",
    "sdkVersion": "54.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#111F45"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.andhrauniversity.universe"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#111F45"
      },
      "package": "com.andhrauniversity.universe",
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "web": {
      "favicon": "./assets/icon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-audio",
      "expo-video",
      "expo-web-browser"
    ],
    "extra": {
      "eas": {
        "projectId": "af3319bd-b19e-4e2a-87fc-fc4f44793cbc"
      }
    }
  }
}
